# shellcheck shell=bash
# zsh is mostly compatible with bash

if [[ -n "${ZSH_DEBUGRC}" ]]; then
    zmodload zsh/zprof
fi

# --- Oh My Zsh ---
export ZSH="$HOME/.oh-my-zsh"  # Path to Oh My Zsh installation.
export ZSH_CUSTOM="$HOME/.oh-my-zsh-custom"  # Path to Oh My Zsh custom directory.
export ZSH_CACHE_DIR="$HOME/.cache/oh-my-zsh"  # Oh My Zsh cache directory.

zstyle ':omz:update' mode disabled  # disable automatic updates

plugins=(
    chezmoi
    mise
    rust
    starship
    uv
    zellij
    colored-man-pages
    zsh-autosuggestions
    zsh-syntax-highlighting
)

source "$ZSH/oh-my-zsh.sh"

ZSH_HIGHLIGHT_HIGHLIGHTERS+=(brackets pattern)
typeset -A ZSH_HIGHLIGHT_PATTERNS
ZSH_HIGHLIGHT_PATTERNS+=(['rm -rf *']='fg=white,bold,bg=red')

# --- Check for tools updates ---
source "$HOME/.zsh/check_tools_updates.zsh"

# --- Aliases ---
# Profile `.zshrc`
alias profile_zshrc='time ZSH_DEBUGRC=1 zsh -i -c exit'

if [[ -n "${ZSH_DEBUGRC}" ]]; then
    zprof
fi
