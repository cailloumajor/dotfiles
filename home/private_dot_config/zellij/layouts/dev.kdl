layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="status-bar"
        }
    }

    tab name="Editor" {
        pane {
            borderless true
            command "zellij-editor"
        }
    }

    tab name="Git" {
        pane {
            borderless true
            command "zellij-gitui"
        }
    }

    tab name="Terminal" {
        pane borderless=true
    }
}

session_serialization false
