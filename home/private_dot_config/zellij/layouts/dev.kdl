layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="status-bar"
        }
    }
    tab name="Editor" {
        pane {
            borderless true
            command "mise"
            args "exec" "--" "hx" "."
        }
    }
    tab name="GitUI" {
        pane {
            borderless true
            command "mise"
            args "exec" "--" "gitui"
        }
    }
    tab name="Terminal" {
        pane borderless=true
    }
}
