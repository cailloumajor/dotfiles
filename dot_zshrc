# shellcheck shell=bash
# zsh is mostly compatible with bash

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/bin" ] ; then
    PATH="$HOME/bin:$PATH"
fi

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/.local/bin" ] ; then
    PATH="$HOME/.local/bin:$PATH"
fi

export EDITOR="/usr/bin/code"

export DEVBOX_NO_PROMPT=1

source "${HOME}/.zsh/async.zsh"
async_init

function _devbox_check_callback {
    local return_code="$2"
    local output="$3"
    local stderr="$5"

    async_stop_worker devbox_check_outdated

    if (( return_code != 0 )); then
        zle -I
        echo "Checking devbox outdated packages failed:"
        echo "${stderr}"
    fi

    if [[ -n "${output}" ]]; then
        zle -I
        echo "📦 devbox packages updates available:"
        echo "${result_file}"
        echo "  → Use 'devbox global update' to update"
    fi
}

function _devbox_check_outdated {
    async_start_worker devbox_check_outdated
    async_register_callback devbox_check_outdated _devbox_check_callback
    async_job devbox_check_outdated devbox global list --outdated
}

# Allow Helix to run in its own terminal emulator, thus using a different font.
function hx {
    alacritty --config-file ~/.config/alacritty/helix.toml --command hx "$@" & disown
}

if command -v devbox >/dev/null; then
    eval "$(devbox global shellenv --init-hook)"

    # zsh-completions
    fpath+="${DEVBOX_PACKAGES_DIR}/share/zsh/site-functions"
    autoload -U compinit && compinit

    source "${DEVBOX_PACKAGES_DIR}/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh"

    # Oh My Zsh
    export ZSH="${DEVBOX_PACKAGES_DIR}/share/oh-my-zsh"
    # shellcheck disable=SC2034
    ZSH_THEME=""
    # shellcheck disable=SC2034
    plugins=(
        colored-man-pages
    )
    source "$ZSH/oh-my-zsh.sh"

    eval "$(devbox completion zsh)"

    eval "$(starship init zsh)"

    eval "$(direnv hook zsh)"

    eval "$(uv generate-shell-completion zsh)"

    source "${DEVBOX_PACKAGES_DIR}/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
    ZSH_HIGHLIGHT_HIGHLIGHTERS+=(brackets pattern)
    typeset -A ZSH_HIGHLIGHT_PATTERNS
    ZSH_HIGHLIGHT_PATTERNS+=('rm -rf *' 'fg=white,bold,bg=red')

    _devbox_check_outdated
else
    echo "/!\ devbox (https://www.jetify.com/docs/devbox) is not installed,"
    echo "    please install it, run 'devbox global install', and restart the shell"
fi
